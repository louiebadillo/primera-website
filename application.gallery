<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Primera renovation gallery — real Calgary project photos from happy homeowners.">

    <title>Gallery — Primera</title>

    <!-- Fav Icon -->
    <link rel="icon" type="image/png" href="assets/imgs/logo/primeralogosmall.png">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- All CSS files -->
    <link rel="stylesheet" href="assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="assets/css/all.min.css">
    <link rel="stylesheet" href="assets/css/swiper-bundle.min.css">
    <link rel="stylesheet" href="assets/css/progressbar.css">
    <link rel="stylesheet" href="assets/css/meanmenu.min.css">
    <link rel="stylesheet" href="assets/css/master.css">
    <link rel="stylesheet" href="style.css">
</head>


<body class="page-application">
    <!-- Cursor Animation -->
    <div class="cursor1"></div>
    <div class="cursor2"></div>

    <!-- Testimonial play cursor (hidden: testimonials section not used on gallery page) -->
    <div class="cursor" id="client_cursor" hidden>Play</div>


    <!-- Preloader -->
    <div class="preloader">
        <div class="loading">
            <div class="bar bar1"></div>
            <div class="bar bar2"></div>
            <div class="bar bar3"></div>
            <div class="bar bar4"></div>
            <div class="bar bar5"></div>
            <div class="bar bar6"></div>
            <div class="bar bar7"></div>
            <div class="bar bar8"></div>
        </div>
    </div>


    <!-- Switcher Area Start -->
    <div class="switcher__area">
        <div class="switcher__icon">
            <button id="switcher_open"><i class="fa-solid fa-gear"></i></button>
            <button id="switcher_close"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="switcher__items">
            <div class="switcher__item">
                <div class="switch__title-wrap">
                    <h2 class="switcher__title">Cursor</h2>
                </div>
                <div class="switcher__btn">
                    <select name="cursor-style" id="cursor_style">
            <option value="1">default</option>
            <option selected value="2">animated</option>
          </select>
                </div>
            </div>

            <div class="switcher__item">
                <div class="switch__title-wrap">
                    <h2 class="switcher__title">mode</h2>
                </div>
                <div class="switcher__btn mode-type wc-col-2">
                    <button class="active" data-mode="light">light</button>
                    <button data-mode="dark">dark</button>
                </div>
            </div>

            <div class="switcher__item">
                <div class="switch__title-wrap">
                    <h2 class="switcher__title">Language Support</h2>
                </div>
                <div class="switcher__btn lang_dir wc-col-2">
                    <button class="active" data-mode="ltr">AR</button>
                    <button data-mode="rtl">EN</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Switcher Area End -->



    <!-- Scroll Smoother -->
    <div class="has-smooth" id="has_smooth"></div>


    <!-- Go Top Button -->
    <button id="scroll_top" class="scroll-top"><i class="fa-solid fa-arrow-up"></i></button>


    <div id="header-partial"></div>
    <!-- Offcanvas area end -->


    <div id="smooth-wrapper">
        <div id="smooth-content">
            <main>

                <!-- Gallery intro -->
                <section class="about__area gallery-intro">
                    <div class="container line g-0 pt-140 pb-130">
                        <span class="line-3"></span>
                        <div class="row">
                            <div class="col-xxl-12">
                                <div class="about__title-wrapper">
                                    <p class="sec-sub-title title-anim">Gallery</p>
                                    <h1 class="sec-title title-anim">Years of Calgary projects—and homeowners who still love coming home.</h1>
                                </div>

                                <div class="about__content-wrapper">
                                    <div class="about__img">
                                        <div class="img-anim">
                                            <img src="assets/imgs/about/1/renovationhero1.jpg" alt="Completed renovation interior" data-speed="0.3">
                                        </div>

                                        <div class="about__img-right">
                                            <img src="assets/imgs/about/1/samples.jpg" alt="Finish and material samples from Primera projects" data-speed="0.5">
                                        </div>
                                    </div>

                                    <div class="about__content gallery-intro__lead">
                                        <p>Browse real photos from kitchens, basements, baths, flooring, feature walls, exteriors, and whole-home transformations we&apos;ve delivered across the city. Open any project below—kitchens and baths can be a single photo or a full swipe gallery; other categories are multi-photo galleries.</p>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </section>
                <!-- Gallery intro end -->

                <!-- Before & after gallery by category (manifest-driven; run: node scripts/generate-before-after-manifest.mjs) -->
                <section class="portfolio__area gallery__section gallery__before-after pb-110" data-gallery-category="basement-suites">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Basement suites</h2>
                                <p class="gallery__before-after-sub gallery__helper">Tap a project to view photos.</p>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <section class="portfolio__area gallery__section gallery__before-after pb-110" data-gallery-category="kitchen">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Kitchens</h2>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <section class="portfolio__area gallery__section gallery__before-after pb-110" data-gallery-category="bathroom">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Bathrooms</h2>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <section class="portfolio__area gallery__section gallery__before-after pb-110" data-gallery-category="feature-walls">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Feature walls</h2>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <section class="portfolio__area gallery__section gallery__before-after pb-110" data-gallery-category="flooring">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Flooring</h2>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <section class="portfolio__area gallery__section gallery__before-after pb-140" data-gallery-category="exteriors">
                    <div class="container">
                        <div class="row top_row">
                            <div class="col-xxl-12">
                                <h2 class="portfolio__text">Exteriors</h2>
                            </div>
                        </div>
                        <div class="before-after-category-root">
                            <div class="portfolio__list-1 before-after-grid__list before-after-category__grid" aria-live="polite"></div>
                            <p class="before-after-category__empty before-after-grid__empty" hidden>Projects coming soon.</p>
                        </div>
                    </div>
                </section>

                <!-- Workflow area start -->
                <section class="workflow__area">
                    <div class="container g-0 line pt-140 pb-140">
                        <div class="line-3"></div>
                        <div class="row">
                            <div class="col-xxl-12">
                                <div class="sec-title-wrapper">
                                    <h2 class="sec-sub-title title-anim">Workflow</h2>
                                    <h3 class="sec-title title-anim">How we work</h3>
                                </div>
                            </div>

                            <div class="col-xxl-12">
                                <div class="swiper workflow__slider ">
                                    <div class="swiper-wrapper">
                                        <div class="swiper-slide workflow__slide fade_left">
                                            <h4 class="workflow__step">step 01</h4>
                                            <h5 class="workflow__number">01</h5>
                                            <h6 class="workflow__title">Consultation &amp; Quote</h6>
                                            <p>We discuss your vision, assess the space, and provide a detailed quote.</p>
                                        </div>

                                        <div class="swiper-slide workflow__slide fade_left">
                                            <h4 class="workflow__step">step 02</h4>
                                            <h5 class="workflow__number">02</h5>
                                            <h6 class="workflow__title">Design &amp; Planning</h6>
                                            <p>We create a plan, select materials, and finalize timelines.</p>
                                        </div>

                                        <div class="swiper-slide workflow__slide fade_left">
                                            <h4 class="workflow__step">step 03</h4>
                                            <h5 class="workflow__number">03</h5>
                                            <h6 class="workflow__title">Construction &amp; Installation</h6>
                                            <p>Our team executes the renovation with quality craftsmanship.</p>
                                        </div>

                                        <div class="swiper-slide workflow__slide fade_left">
                                            <h4 class="workflow__step">step 04</h4>
                                            <h5 class="workflow__number">04</h5>
                                            <h6 class="workflow__title">Walkthrough &amp; Handoff</h6>
                                            <p>We do a final walkthrough and hand over your completed project.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Workflow area end -->

                <!-- Contact Us section start -->
                <section class="contact-app__area pt-110 pb-200">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-xxl-4 col-xl-4 col-lg-5 col-md-6">
                                <div class="contact-app__info">
                                    <h3 class="sec-title" style="color: #E1AC00">Contact Us <br>to get a Free Quote</h3>
                                    <ul class="contact-app__details">
                                        <li>Calgary -- Airdrie -- Chestermere</li>
                                        <li><a href="tel:14037077617">403-707-7617</a></li>
                                        <li><a href="mailto:primerayyc@gmail.com">primerayyc@gmail.com</a></li>
                                    </ul>
                                    <div class="contact-app__social">
                                        <p class="contact-app__social-label">Follow us:</p>
                                        <a href="https://www.facebook.com/yycprimera/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><img src="assets/imgs/icon/facebook.png" alt="Facebook" class="contact-app__social-icon"></a>
                                        <a href="https://www.instagram.com/primerayyc/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><img src="assets/imgs/icon/instagram.png" alt="Instagram" class="contact-app__social-icon"></a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-8 col-xl-8 col-lg-7 col-md-6">
                                <form class="contact-app__form" action="https://api.web3forms.com/submit" method="POST">
                                    <div class="web3forms-feedback" tabindex="-1" role="status" aria-live="polite" hidden></div>
                                    <input type="hidden" name="access_key" value="a88f174c-9667-4e8a-a162-91845b0a8f2a">
                                    <input type="hidden" name="from_name" value="Primera website — Gallery">
                                    <input type="hidden" name="subject" value="Gallery page contact">
                                    <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <input type="text" name="name" placeholder="Your Name" required>
                                        </div>
                                        <div class="col-md-6">
                                            <input type="email" name="email" placeholder="Your Email" required>
                                        </div>
                                        <div class="col-12">
                                            <input type="tel" name="phone" placeholder="Phone (optional)">
                                        </div>
                                        <div class="col-12">
                                            <textarea name="message" rows="4" placeholder="Your Message" required></textarea>
                                        </div>
                                        <div class="col-12">
                                            <button type="submit" class="wc-btn-primary btn-hover btn-item"><span></span> Send Message <i class="fa-solid fa-arrow-right"></i></button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Contact Us section end -->

                <!-- Testimonial area start (hidden on gallery page) -->
                <section class="testimonial__area" hidden aria-hidden="true">
                    <div class="container g-0 line pt-110 pb-100">
                        <span class="line-3"></span>
                        <div class="row">
                            <div class="col-xxl-8 col-xl-8 col-lg-8 col-md-8">
                                <div class="testimonial__wrapper">
                                    <div class="testimonial__item item-1">
                                        <div class="button modal-trigger">
                                            <div class="testimonial__img b-right">
                                                <img src="assets/imgs/testimonial/1/1.png" alt="Testimonial">
                                            </div>
                                            <h2 class="testimonial__title">Nada amr</h2>
                                            <h3 class="testimonial__role">Special, Customer</h3>
                                        </div>
                                    </div>
                                    <div class="sec-title-wrapper text-anim">
                                        <h4 class="sec-sub-title">Testimonials</h4>
                                        <h5 class="sec-title title-anim">Clients <br>feedback</h5>                                    </div>
                                </div>
                                <div class="testimonial__item item-2">
                                    <div class="button modal-trigger-2">
                                        <div class="testimonial__img b-left">
                                            <img src="assets/imgs/testimonial/1/3.png" alt="Testimonial Image">
                                        </div>
                                        <h2 class="testimonial__title">Ahmad Ali</h2>
                                        <h3 class="testimonial__role">Special, Customer</h3>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4">
                                <div class="testimonial__item item-3 img-">
                                    <div class="button modal-trigger-3">
                                        <div class="testimonial__img b-left">
                                            <img src="assets/imgs/testimonial/1/2.png" alt="Testimonial Image">
                                        </div>
                                        <h2 class="testimonial__title">Adam Mahmoud</h2>
                                        <h3 class="testimonial__role">Special, Customer</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Testimonial area end -->

            </main>

            <div id="footer-partial"></div>

        </div>
    </div>

    <!-- Gallery lightbox (white 70% backdrop) -->
    <div class="gallery-lightbox" id="gallery_lightbox" aria-hidden="true">
        <div class="gallery-lightbox__panel" role="dialog" aria-modal="true" aria-label="Project photos">
            <button class="gallery-lightbox__close" type="button" id="gallery_lightbox_close" aria-label="Close">
                <span aria-hidden="true">×</span>
            </button>

            <h3 class="gallery-lightbox__title" id="gallery_lightbox_title"></h3>

            <div class="swiper gallery-lightbox__swiper" id="gallery_lightbox_swiper">
                <div class="swiper-wrapper">
                    <!-- Slides injected by gallery-before-after.js -->
                </div>
            </div>

            <div class="gallery-lightbox-control gallery-lightbox-control--prev" data-dir="prev">
                <button class="gallery-lightbox-control-btn" type="button" aria-label="Previous slide">
                    <span class="gallery-lightbox-control-btn-icon" aria-hidden="true">
                        <svg class="caret-left-icon--small" viewBox="0 0 9 16">
                            <polyline fill="none" stroke-miterlimit="10" points="6.9,1.2 2,7.9 6.9,14.7 "></polyline>
                        </svg>
                    </span>
                </button>
            </div>
            <div class="gallery-lightbox-control gallery-lightbox-control--next" data-dir="next">
                <button class="gallery-lightbox-control-btn" type="button" aria-label="Next slide">
                    <span class="gallery-lightbox-control-btn-icon" aria-hidden="true">
                        <svg class="caret-right-icon--small" viewBox="0 0 9 16">
                            <polyline fill="none" stroke-miterlimit="10" points="2,1.2 6.9,7.9 2,14.7 "></polyline>
                        </svg>
                    </span>
                </button>
            </div>
        </div>
    </div>

    <!-- All JS files (include-partials must run first) -->
    <script src="assets/js/include-partials.js"></script>
    <script src="assets/js/jquery-3.6.0.min.js"></script>
    <script src="assets/js/bootstrap.bundle.min.js"></script>
    <script src="assets/js/swiper-bundle.min.js"></script>
    <script src="assets/js/counter.js"></script>
    <script src="assets/js/gsap.min.js"></script>
    <script src="assets/js/ScrollTrigger.min.js"></script>
    <script src="assets/js/ScrollToPlugin.min.js"></script>
    <script src="assets/js/ScrollSmoother.min.js"></script>
    <script src="assets/js/SplitText.min.js"></script>
    <script src="assets/js/chroma.min.js"></script>
    <script src="assets/js/mixitup.min.js"></script>
    <script src="assets/js/vanilla-tilt.js"></script>
    <script src="assets/js/jquery.meanmenu.min.js"></script>
    <script src="assets/js/gallery-before-after.js"></script>
    <script src="assets/js/main.js"></script>
    <script src="assets/js/web3forms-submit.js"></script>

</body>

</html>
